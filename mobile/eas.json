{
    "cli": {
        "version": ">= 12.5.0",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal"
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true
            }
        },
        "production": {
            "env": {
                "EXPO_PUBLIC_APP_URL": "https://REPLACE_WITH_PRODUCTION_URL"
            }
        }
    },
    "submit": {
        "production": {}
    }
}